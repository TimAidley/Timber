<!doctype html><html lang="{{ page.lang | default: 'en' }}"><head><title>{{ seo.title }}</title><link rel="canonical" href="{{ seo.canonical }}">{% for alt in seo.alternates %}<link rel="alternate" hreflang="{{ alt.lang }}" href="{{ alt.href }}">{% endfor %}</head><body class="posts"><h1>{{ page.title }}</h1>{% if page.translations.size > 1 %}<nav class="langs">{% for t in page.translations %}<a href="{{ t.url }}"{% if t.lang == page.lang %} aria-current="true"{% endif %}>{{ t.lang }}</a>{% endfor %}</nav>{% endif %}{{ content }}</body></html>
