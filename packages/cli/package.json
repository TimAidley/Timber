{
  "name": "@timber/cli",
  "version": "0.0.0",
  "description": "Timber Node CLI — the CI build entry point for the shared generator.",
  "type": "module",
  "bin": {
    "timber": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "start": "node ./dist/index.js"
  },
  "dependencies": {
    "@timber/content": "workspace:*",
    "@timber/generator": "workspace:*",
    "@timber/jekyll-compat": "workspace:*",
    "@timber/sass": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2"
  }
}
