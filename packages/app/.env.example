# Timber editor app config (Vite env). Copy to `.env` and adjust.

# The content repo this instance edits.
VITE_TIMBER_OWNER=TimAidley
VITE_TIMBER_REPO=Timber-test-sandbox

# Production OAuth (SPEC §9). Set BOTH to enable "Sign in with GitHub" via the
# @timber/oauth-broker; leave unset to use the dev paste-a-PAT gate.
#   VITE_TIMBER_OAUTH_CLIENT_ID  — the OAuth App's public client id
#   VITE_TIMBER_OAUTH_BROKER_URL — the deployed broker's URL (see packages/oauth-broker/README.md)
# VITE_TIMBER_OAUTH_CLIENT_ID=Iv1.0123456789abcdef
# VITE_TIMBER_OAUTH_BROKER_URL=https://timber-oauth-broker.you.workers.dev

# Build provenance (SPEC §12) — set by deploy.yml at build time, not by hand. They let
# the editor notice when the Timber branch it follows has moved past the commit it was
# built from and offer a one-click redeploy. Leave unset locally: no provenance, no banner.
#   VITE_TIMBER_UPSTREAM_REPO — the Timber repo the editor was built from (owner/repo)
#   VITE_TIMBER_UPSTREAM_REF  — the ref it follows (a branch like `main`, or a pinned tag)
#   VITE_TIMBER_BUILD_SHA     — the commit SHA of that ref at build time
# VITE_TIMBER_UPSTREAM_REPO=TimAidley/Timber
# VITE_TIMBER_UPSTREAM_REF=main
# VITE_TIMBER_BUILD_SHA=0000000000000000000000000000000000000000
