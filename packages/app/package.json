{
  "name": "@timber/app",
  "version": "0.0.0",
  "description": "Timber's browser editor: schema-driven forms + Milkdown body editor + in-browser live preview. Browser-only React SPA (not isomorphic).",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc",
    "preview": "vite preview",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@milkdown/kit": "^7.6.0",
    "@milkdown/react": "^7.6.0",
    "@timber/content": "workspace:*",
    "@timber/generator": "workspace:*",
    "@timber/github": "workspace:*",
    "dompurify": "^3.4.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remark-stringify": "^11.0.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.3"
  }
}
