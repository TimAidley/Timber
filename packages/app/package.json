{
  "name": "@timber/app",
  "version": "0.0.0",
  "description": "Timber's browser editor: schema-driven forms + Milkdown body editor + in-browser live preview. Browser-only React SPA (not isomorphic).",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc",
    "preview": "vite preview",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@milkdown/kit": "^7.6.0",
    "@milkdown/react": "^7.6.0",
    "@prosemirror-adapter/react": "^0.5.3",
    "@timber/content": "workspace:*",
    "@timber/generator": "workspace:*",
    "@timber/github": "workspace:*",
    "@timber/gitea": "workspace:*",
    "@timber/gitlab": "workspace:*",
    "@timber/host": "workspace:*",
    "codemirror": "^6.0.2",
    "diff": "^9.0.0",
    "dompurify": "^3.4.11",
    "mdast-util-directive": "^3.1.0",
    "micromark-extension-directive": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remark-stringify": "^11.0.0",
    "unist-util-visit": "^5.1.0",
    "yaml": "^2.6.1",
    "@timber/jekyll-compat": "workspace:*",
    "@timber/sass": "workspace:*",
    "fflate": "^0.8.2",
    "@timber/eleventy-compat": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.3"
  }
}
